{
  "name": "daggerheart-gm",
  "version": "1.0.0",
  "description": "A GM tool for Daggerheart",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file=.env server.js",
    "crawl": "node --env-file=.env scripts/crawl.js",
    "crawl:fcg": "node --env-file=.env scripts/crawl.js fcg",
    "crawl:hod": "node --env-file=.env scripts/crawl.js hod",
    "refresh:daggerstack": "node scripts/refresh-daggerstack-uuids.js",
    "dev": "node --env-file=.env --watch server.js & npm run dev:css & npm run dev:js",
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/styles.css --minify",
    "dev:css": "tailwindcss -i ./src/input.css -o ./public/styles.css --watch",
    "build:js": "esbuild src/client/app.jsx --bundle --format=esm --jsx=automatic --external:react --external:react-dom --external:react/jsx-runtime --external:firebase/app --external:firebase/auth --external:lucide-react --external:marked --external:@3d-dice/dice-box-threejs --outdir=public",
    "dev:js": "esbuild src/client/app.jsx --bundle --format=esm --jsx=automatic --external:react --external:react-dom --external:react/jsx-runtime --external:firebase/app --external:firebase/auth --external:lucide-react --external:marked --external:@3d-dice/dice-box-threejs --outdir=public --watch",
    "test": "vitest run && npx playwright test",
    "test:unit": "vitest run",
    "test:browser": "npx playwright test"
  },
  "dependencies": {
    "@3d-dice/dice-box-threejs": "^0.0.12",
    "@huggingface/inference": "^4.13.14",
    "@supabase/supabase-js": "^2.99.0",
    "@tanstack/react-virtual": "^3.13.0",
    "compression": "^1.8.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.7.0",
    "multer": "^2.1.0",
    "node-cron": "^4.2.1",
    "pg": "^8.19.0",
    "puppeteer": "^24.37.5",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.1",
    "esbuild": "^0.27.3",
    "tailwindcss": "^4.2.1",
    "vitest": "^4.0.18"
  }
}
